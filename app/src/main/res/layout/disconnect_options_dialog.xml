<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/card_bg"
        android:elevation="2dp"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btn_back_options"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="返回"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/mode_disconnect_title"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <!-- 已选择包名 -->
    <TextView
        android:id="@+id/tv_selected_package"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:textSize="13sp"
        android:textColor="@color/accent_primary"
        android:background="@drawable/bg_rounded"
        android:backgroundTint="@color/accent_light"
        android:gravity="center" />

    <!-- 开关卡片 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:contentPadding="0dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:id="@+id/row_enable_disconnect"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/disconnect_enable"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_disconnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/accent_primary"
                android:trackTint="@color/accent_light" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 选择包名卡片 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:contentPadding="0dp"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:id="@+id/row_select_package"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/disconnect_select_pkg"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_back"
                android:rotation="180"
                android:contentDescription="进入"
                android:tint="@color/text_hint" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>
